# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT environment variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy to backend/.env before starting the backend:
#   cp .env.local.example backend/.env
#
# For Docker Compose, copy to the project root instead:
#   cp .env.local.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Neonatal Resuscitation Simulator
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite — created automatically at backend/neonatal.db on first run.
DATABASE_URL=sqlite+aiosqlite:///./neonatal.db

# ── Security ─────────────────────────────────────────────────────────────────
# Any string works locally; generate a real secret for any networked deployment.
JWT_SECRET_KEY=local-dev-secret-not-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allow the Vite dev server and the Vite preview server.
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173"]

# ── Frontend build args (Docker Compose only) ────────────────────────────────
# Baked into the compiled JS at build time.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
