# Neonatal Resuscitation Simulator — environment variables
#
# Local development:
#   cp .env.example backend/.env
#   # edit backend/.env — set JWT_SECRET_KEY at minimum
#   cd backend && uvicorn app.main:app --host 127.0.0.1 --port 8000
#
# Docker (docker-compose reads this file from the project root automatically):
#   cp .env.example .env
#   # set JWT_SECRET_KEY
#   docker compose up --build

# ── Application ──────────────────────────────────────────────────────────────

APP_NAME=Neonatal Resuscitation Simulator

# Set to false in production.
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────

# SQLite (recommended for local use and demo):
DATABASE_URL=sqlite+aiosqlite:///./neonatal.db

# PostgreSQL (optional — for multi-user or production deployment):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neonatal

# ── Security ─────────────────────────────────────────────────────────────────

# Replace with a random secret before any networked deployment.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT authentication is scaffolded but not yet enforced on routes.
JWT_SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────

# Origins the browser is allowed to connect from.
# Must include the address where the frontend runs.
# Format: JSON array string or comma-separated list.
#
# Local development (Vite default port):
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
#
# If you use a different frontend port, add it here:
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# ── Scenarios (optional override) ────────────────────────────────────────────

# Absolute path to the scenarios/ directory.
# Default is computed automatically relative to config.py — only set this
# if the default path is wrong (e.g. a non-standard Docker layout).
# SCENARIOS_DIR=/app/scenarios

# ── Docker frontend build args (docker-compose only) ─────────────────────────

# Backend address baked into the compiled frontend JS.
# Must match the host:port where the backend is reachable from the browser.
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
