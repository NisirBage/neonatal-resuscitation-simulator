{
  "id": "baby_birth",
  "name": "Neonatal Resuscitation — Voice-First Workflow",
  "version": "2.0.0",
  "initial_state": "baby_born",
  "metadata": {
    "source": "professor_neonatal_resuscitation_flowcharts",
    "description": "Voice-first neonatal resuscitation workflow. Student responds YES or NO to each spoken prompt.",
    "protocol_logic_location": "scenario_json"
  },
  "states": [
    {
      "id": "baby_born",
      "name": "Baby Born",
      "description": "The baby has just been born. Birth timer starts automatically.",
      "metadata": {
        "voice_prompt": "Baby is born at {TIME}."
      },
      "actions": [],
      "timers": [
        {
          "id": "birth_timer",
          "duration_seconds": 60,
          "event": "birth_timer_elapsed",
          "auto_start": true,
          "metadata": { "label": "Birth timer" }
        },
        {
          "id": "baby_born_delay_timer",
          "duration_seconds": 15,
          "event": "baby_born_delay_elapsed",
          "auto_start": true,
          "metadata": { "label": "Birth announcement delay" }
        }
      ],
      "transitions": [
        {
          "id": "baby_born_delay_elapsed",
          "trigger": "timer",
          "target_state": "put_on_mothers_chest",
          "timer_id": "baby_born_delay_timer"
        },
        {
          "id": "birth_timer_elapsed",
          "trigger": "timer",
          "target_state": "put_on_mothers_chest",
          "timer_id": "birth_timer"
        },
        {
          "id": "instructor_start_birth_workflow",
          "trigger": "instructor",
          "target_state": "put_on_mothers_chest",
          "instructor_event": "start_birth_workflow"
        }
      ]
    },
    {
      "id": "put_on_mothers_chest",
      "name": "Put Baby On Mother's Abdomen",
      "description": "Instruct the student to place the baby on the mother's abdomen.",
      "metadata": {
        "voice_prompt": "Put baby on mother's abdomen."
      },
      "actions": [
        {
          "id": "placed_on_chest",
          "type": "yes_no",
          "prompt": "Have you placed the baby on the mother's abdomen?",
          "options": ["yes", "no"],
          "metadata": { "role": "student" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "chest_placement_done",
          "trigger": "action",
          "target_state": "crying_assessment",
          "action_id": "placed_on_chest",
          "expected_response": "yes"
        },
        {
          "id": "instructor_advance_to_crying",
          "trigger": "instructor",
          "target_state": "crying_assessment",
          "instructor_event": "advance_to_crying_assessment"
        }
      ]
    },
    {
      "id": "crying_assessment",
      "name": "Is Baby Crying?",
      "description": "Assess whether the baby is crying.",
      "metadata": {
        "voice_prompt": "Is baby crying?"
      },
      "actions": [
        {
          "id": "is_baby_crying",
          "type": "yes_no",
          "prompt": "Is the baby crying?",
          "options": ["yes", "no"],
          "metadata": { "assessment": "crying" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "baby_crying",
          "trigger": "action",
          "target_state": "routine_care",
          "action_id": "is_baby_crying",
          "expected_response": "yes"
        },
        {
          "id": "baby_not_crying",
          "trigger": "action",
          "target_state": "apnea_assessment",
          "action_id": "is_baby_crying",
          "expected_response": "no"
        },
        {
          "id": "instructor_marks_not_crying",
          "trigger": "instructor",
          "target_state": "apnea_assessment",
          "instructor_event": "baby_not_crying"
        }
      ]
    },
    {
      "id": "apnea_assessment",
      "name": "Apnea Assessment",
      "description": "Assess whether the baby has apnea or ineffective breathing.",
      "metadata": {
        "voice_prompt": "Does baby have apnea?"
      },
      "actions": [
        {
          "id": "is_apneic",
          "type": "yes_no",
          "prompt": "Does the baby have apnea or ineffective breathing?",
          "options": ["yes", "no"],
          "metadata": { "assessment": "breathing" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "apnea_yes",
          "trigger": "action",
          "target_state": "heart_rate_assessment",
          "action_id": "is_apneic",
          "expected_response": "yes"
        },
        {
          "id": "apnea_no",
          "trigger": "action",
          "target_state": "heart_rate_assessment",
          "action_id": "is_apneic",
          "expected_response": "no"
        },
        {
          "id": "instructor_sends_to_hr",
          "trigger": "instructor",
          "target_state": "heart_rate_assessment",
          "instructor_event": "assess_heart_rate"
        }
      ]
    },
    {
      "id": "heart_rate_assessment",
      "name": "Heart Rate Assessment",
      "description": "Measure heart rate. Is it greater than 100 bpm?",
      "metadata": {
        "voice_prompt": "Measure heart rate. Is the heart rate greater than 100 beats per minute?"
      },
      "actions": [
        {
          "id": "hr_above_100",
          "type": "yes_no",
          "prompt": "Is the heart rate greater than 100 bpm?",
          "options": ["yes", "no"],
          "metadata": { "assessment": "heart_rate" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "hr_sufficient",
          "trigger": "action",
          "target_state": "simulation_complete",
          "action_id": "hr_above_100",
          "expected_response": "yes"
        },
        {
          "id": "hr_insufficient",
          "trigger": "action",
          "target_state": "ventilation_path",
          "action_id": "hr_above_100",
          "expected_response": "no"
        },
        {
          "id": "instructor_hr_100_or_more",
          "trigger": "instructor",
          "target_state": "simulation_complete",
          "instructor_event": "heart_rate_100_or_more"
        },
        {
          "id": "instructor_hr_under_100",
          "trigger": "instructor",
          "target_state": "ventilation_path",
          "instructor_event": "heart_rate_under_100"
        }
      ]
    },
    {
      "id": "ventilation_path",
      "name": "Start Ventilation",
      "description": "Instruct student to start PPV and apply the pulse oximeter.",
      "metadata": {
        "voice_prompt": "Start ventilation and apply pulse oximeter."
      },
      "actions": [
        {
          "id": "start_ventilation",
          "type": "text",
          "prompt": "Say 'Ventilation started' to confirm.",
          "options": [],
          "metadata": { "intervention": "ventilation" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "ventilation_started",
          "trigger": "action",
          "target_state": "ventilation_in_progress",
          "action_id": "start_ventilation",
          "text_match": "ventilation"
        },
        {
          "id": "instructor_start_ventilation",
          "trigger": "instructor",
          "target_state": "ventilation_in_progress",
          "instructor_event": "ventilation_started"
        }
      ]
    },
    {
      "id": "ventilation_in_progress",
      "name": "Ventilation In Progress",
      "description": "Ventilation is underway. 30-second timer before heart rate reassessment.",
      "metadata": {
        "voice_prompt": "Measure heart rate every 15 seconds."
      },
      "actions": [
        {
          "id": "acknowledge_ventilation",
          "type": "yes_no",
          "prompt": "Acknowledge ventilation is in progress?",
          "options": ["yes", "no"],
          "metadata": { "fallback_only": true }
        }
      ],
      "timers": [
        {
          "id": "ventilation_timer",
          "duration_seconds": 30,
          "event": "ventilation_timer_elapsed",
          "auto_start": true,
          "metadata": { "label": "Ventilation timer" }
        }
      ],
      "transitions": [
        {
          "id": "ventilation_acknowledged",
          "trigger": "action",
          "target_state": "heart_rate_after_ventilation",
          "action_id": "acknowledge_ventilation",
          "expected_response": "yes"
        },
        {
          "id": "ventilation_timer_done",
          "trigger": "timer",
          "target_state": "heart_rate_after_ventilation",
          "timer_id": "ventilation_timer"
        },
        {
          "id": "instructor_ventilation_complete",
          "trigger": "instructor",
          "target_state": "heart_rate_after_ventilation",
          "instructor_event": "ventilation_timer_complete"
        }
      ]
    },
    {
      "id": "heart_rate_after_ventilation",
      "name": "Is Heart Rate Increasing?",
      "description": "After ventilation: is the heart rate increasing?",
      "metadata": {
        "voice_prompt": "Is the heart rate increasing?"
      },
      "actions": [
        {
          "id": "hr_increasing",
          "type": "yes_no",
          "prompt": "Is the heart rate increasing?",
          "options": ["yes", "no"],
          "metadata": { "assessment": "heart_rate_trend" }
        }
      ],
      "timers": [],
      "transitions": [
        {
          "id": "hr_increasing_yes",
          "trigger": "action",
          "target_state": "continue_ventilation_15s",
          "action_id": "hr_increasing",
          "expected_response": "yes"
        },
        {
          "id": "hr_increasing_no",
          "trigger": "action",
          "target_state": "ventilation_corrective_steps",
          "action_id": "hr_increasing",
          "expected_response": "no"
        },
        {
          "id": "instructor_hr_increasing",
          "trigger": "instructor",
          "target_state": "continue_ventilation_15s",
          "instructor_event": "heart_rate_increasing"
        },
        {
          "id": "instructor_hr_not_increasing",
          "trigger": "instructor",
          "target_state": "ventilation_corrective_steps",
          "instructor_event": "heart_rate_not_increasing"
        }
      ]
    },
    {
      "id": "ventilation_corrective_steps",
      "name": "Ventilation Corrective Steps",
      "description": "Perform corrective steps: reposition, suction, increase pressure.",
      "metadata": {
        "voice_prompt": "Follow ventilation corrective steps."
      },
      "actions": [
        {
          "id": "corrective_steps_done",
          "type": "yes_no",
          "prompt": "Have you completed all corrective ventilation steps?",
          "options": ["yes", "no"],
          "metadata": { "intervention": "ventilation_correction" }
        }
      ],
      "timers": [
        {
          "id": "corrective_ventilation_timer",
          "duration_seconds": 30,
          "event": "corrective_ventilation_timer_elapsed",
          "auto_start": true,
          "metadata": { "label": "Corrective ventilation timer" }
        }
      ],
      "transitions": [
        {
          "id": "corrective_steps_complete",
          "trigger": "action",
          "target_state": "heart_rate_after_ventilation",
          "action_id": "corrective_steps_done",
          "expected_response": "yes"
        },
        {
          "id": "corrective_ventilation_timer_done",
          "trigger": "timer",
          "target_state": "heart_rate_after_ventilation",
          "timer_id": "corrective_ventilation_timer"
        },
        {
          "id": "instructor_corrective_ventilation_complete",
          "trigger": "instructor",
          "target_state": "heart_rate_after_ventilation",
          "instructor_event": "corrective_ventilation_complete"
        }
      ]
    },
    {
      "id": "continue_ventilation_15s",
      "name": "Continue Ventilation 15 Seconds",
      "description": "Heart rate is increasing — continue ventilation for 15 more seconds.",
      "metadata": {
        "voice_prompt": "Heart rate is increasing. Continue ventilation for 15 seconds and stop."
      },
      "actions": [
        {
          "id": "continue_ventilation",
          "type": "yes_no",
          "prompt": "Continue ventilation for 15 seconds?",
          "options": ["yes", "no"],
          "metadata": { "fallback_only": true }
        }
      ],
      "timers": [
        {
          "id": "continue_ventilation_timer",
          "duration_seconds": 15,
          "event": "continue_ventilation_timer_elapsed",
          "auto_start": true,
          "metadata": { "label": "Continue ventilation timer" }
        }
      ],
      "transitions": [
        {
          "id": "continue_ventilation_confirmed",
          "trigger": "action",
          "target_state": "simulation_complete",
          "action_id": "continue_ventilation",
          "expected_response": "yes"
        },
        {
          "id": "continue_ventilation_timer_done",
          "trigger": "timer",
          "target_state": "simulation_complete",
          "timer_id": "continue_ventilation_timer"
        },
        {
          "id": "instructor_continue_ventilation_complete",
          "trigger": "instructor",
          "target_state": "simulation_complete",
          "instructor_event": "continue_ventilation_complete"
        }
      ]
    },
    {
      "id": "routine_care",
      "name": "Routine Care",
      "description": "Baby is crying and vigorous — perform routine newborn care.",
      "actions": [],
      "timers": [],
      "transitions": [],
      "metadata": {
        "terminal": true,
        "outcome": "routine_care",
        "voice_prompt": "Baby is crying and vigorous. Perform routine care."
      }
    },
    {
      "id": "simulation_complete",
      "name": "Simulation Complete",
      "description": "Resuscitation complete.",
      "actions": [],
      "timers": [],
      "transitions": [],
      "metadata": {
        "terminal": true,
        "outcome": "stop",
        "voice_prompt": "Heart rate is greater than 100 beats per minute. Stop resuscitation protocol."
      }
    }
  ]
}
