        {
          "id": "confirm_birth",
          "type": "yes_no",
          "prompt": "Has the baby been born?",
          "options": [
            "yes",
            "no"
          ],
          "metadata": {
            "role": "student"
          }
        }
      ],
      "timers": [
        {
          "id": "birth_timer",
          "duration_seconds": 60,
          "event": "birth_timer_elapsed",
          "auto_start": true,
          "metadata": {
            "label": "Birth timer"
          }
        }
      ],
      "transitions": [
        {
          "id": "birth_confirmed",
          "trigger": "action",
          "target_state": "put_on_mothers_chest",
          "action_id": "confirm_birth",
          "expected_response": "yes"
        },
        {
          "id": "birth_timer_elapsed",
