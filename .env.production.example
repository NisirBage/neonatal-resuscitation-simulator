# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment variables
# ─────────────────────────────────────────────────────────────────────────────
#
# BACKEND (Railway)
#   Set these in the Railway dashboard under your service → Variables.
#   NEVER commit real values to the repository.
#
# FRONTEND (Vercel)
#   Set VITE_* variables in the Vercel dashboard under
#   Project Settings → Environment Variables → Production.
#   These are baked into the JS bundle at build time — redeploy after changing.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────

# Application display name (appears in logs).
APP_NAME=Neonatal Resuscitation Simulator

# Must be false in production.
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────

# Option A — SQLite on a Railway persistent volume (simplest, recommended for demo):
#   1. In the Railway service, go to Settings → Volumes and attach a volume at /app/data
#   2. Use the path below exactly.
DATABASE_URL=sqlite+aiosqlite:////app/data/neonatal.db

# Option B — Railway PostgreSQL plugin (recommended for multi-instance or high load):
#   1. Add the PostgreSQL plugin to your Railway project.
#   2. Railway injects DATABASE_URL automatically — uncomment the line below and
#      delete the SQLite line above.  The asyncpg driver is already in requirements.txt.
# DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}

# ── Security ─────────────────────────────────────────────────────────────────

# Cryptographically random secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS_GENERATED_ABOVE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────

# Must include the exact Vercel deployment URL (no trailing slash).
# Add preview URLs if you use Vercel branch deployments.
ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# ── Scenarios ────────────────────────────────────────────────────────────────

# Set by the Dockerfile — only override if using a non-standard layout.
SCENARIOS_DIR=/app/scenarios

# ── Frontend (Vercel) — set in Vercel dashboard, NOT here ────────────────────

# Backend REST URL (must be https:// in production).
# VITE_API_BASE_URL=https://your-backend.up.railway.app

# Backend WebSocket URL (must be wss:// when backend is on HTTPS).
# VITE_WS_BASE_URL=wss://your-backend.up.railway.app
